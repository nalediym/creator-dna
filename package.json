{
  "name": "creator-dna",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/web",
    "typecheck": "npm run typecheck --workspace=packages/core --if-present && npm run typecheck --workspace=packages/web --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest run --project eval"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
